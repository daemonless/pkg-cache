#!/bin/sh
# Render and start a managed daemonless pkg-cache appliance config.
mkdir -p /config/log /config/stats /cache /run/pkg-cache
cp /defaults/nginx.conf /run/pkg-cache/nginx.conf

SIZE="${PKG_CACHE_SIZE:-50g}"
UPSTREAM="${PKG_UPSTREAM:-pkg.FreeBSD.org}"
RESOLVER="${PKG_RESOLVER:-}"
if [ -z "${RESOLVER}" ]; then
    RESOLVER=$(awk "/^nameserver[ \t]+/ {print \$2}" /etc/resolv.conf 2>/dev/null | tr "\n" " " | sed "s/ $//")
fi
RESOLVER="${RESOLVER:-1.1.1.1 8.8.8.8}"

sed -i "" "s/max_size=[^ ;]*/max_size=${SIZE}/" /run/pkg-cache/nginx.conf
sed -i "" "s/PKG_UPSTREAM_HOST/${UPSTREAM}/g" /run/pkg-cache/nginx.conf
sed -i "" "s/PKG_RESOLVER/${RESOLVER}/" /run/pkg-cache/nginx.conf

# Pre-create log files so they are owned by bsd (worker process) and not root.
touch /config/log/access.log /config/log/error.log /config/log/goaccess.log
chown -R bsd:bsd /config /cache /run/pkg-cache

# Point nginx at the generated runtime config.
ln -sf /run/pkg-cache/nginx.conf /usr/local/etc/nginx/nginx.conf

# Legacy compat: symlink /data -> /cache if someone still mounts /data.
if [ ! -d /data ]; then
    ln -sf /cache /data
fi

echo "[pkg-cache] upstream=${UPSTREAM} resolver=${RESOLVER} max_size=${SIZE} config=/run/pkg-cache/nginx.conf cache=/cache"
